# =============================================================
# Pager0 / SentinelCall — Environment Variables
# =============================================================
# Copy this file to .env and fill in your keys.
# Any missing key causes that integration to run in demo/mock mode.

# Auth0 — CIBA backchannel auth + Token Vault
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
AUTH0_REDIRECT_URI=

# Bland AI — Phone calls + interactive pathways
BLAND_API_KEY=
BLAND_WEBHOOK_SECRET=

# Ghost CMS — Tiered incident reports
GHOST_URL=
GHOST_ADMIN_API_KEY=
GHOST_WEBHOOK_SECRET=

# TrueFoundry — AI Gateway + model escalation
TRUEFOUNDRY_API_KEY=
TRUEFOUNDRY_ENDPOINT=
TRUEFOUNDRY_PROVIDER_NAME=anthropic

# Overmind — LLM call tracing
OVERMIND_API_KEY=

# Airbyte — Dynamic data connectors
AIRBYTE_API_KEY=

# LLM API Keys (used as fallback when TrueFoundry is unavailable)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# On-call engineer defaults
ON_CALL_PHONE=
ON_CALL_ENGINEER_ID=

# GitHub — Macroscope PR-linked root cause analysis + rollback execution
GITHUB_REPO=
GITHUB_TOKEN=
GITHUB_ROLLBACK_WORKFLOW_ID=
GITHUB_ROLLBACK_REF=main

# Webhook base URL (where Bland sends callbacks)
WEBHOOK_BASE_URL=http://localhost:8000

# Local persistence
PAGER0_DB_PATH=pager0.db

# External remediation executor (optional)
REMEDIATION_WEBHOOK_URL=
REMEDIATION_WEBHOOK_SECRET=
